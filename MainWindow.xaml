<Window x:Class="Cipher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CIPHER" Height="620" Width="900"
        MinHeight="480" MinWidth="700"
        Background="#0C0C0C"
        WindowStyle="SingleBorderWindow"
        FontFamily="Consolas"
        Foreground="#00FF41">

    <Window.Resources>
        <!-- Converter: bool to visibility -->
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Message time format -->
        <Style x:Key="MsgTime" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="Margin" Value="4,0,0,1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ════════════════════════════════════════════════════ -->
        <!--  LOGIN / REGISTER PANEL                              -->
        <!-- ════════════════════════════════════════════════════ -->
        <Grid x:Name="AuthPanel" Background="#0C0C0C" Panel.ZIndex="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                <!-- ASCII logo -->
                <TextBlock x:Name="LegacyLogo" FontFamily="Consolas" FontSize="11" Foreground="#00FF41"
                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,24"
                           Visibility="Collapsed">
<![CDATA[  ██████╗██╗██████╗ ██╗  ██╗███████╗██████╗
 ██╔════╝██║██╔══██╗██║  ██║██╔════╝██╔══██╗
 ██║     ██║██████╔╝███████║█████╗  ██████╔╝
 ██║     ██║██╔═══╝ ██╔══██║██╔══╝  ██╔══██╗
 ╚██████╗██║██║     ██║  ██║███████╗██║  ██║
  ╚═════╝╚═╝╚═╝     ╚═╝  ╚═╝╚══════╝╚═╝  ╚═╝]]>
                </TextBlock>

                <TextBlock x:Name="AuthBrandTitle" FontSize="28" FontWeight="Bold"
                           Foreground="#00FF41" HorizontalAlignment="Center"
                           Margin="0,0,0,10" Text="CIPHER"/>

                <TextBlock FontSize="10" Foreground="#444444" HorizontalAlignment="Center"
                           Margin="0,0,0,32">zero-trust · end-to-end encrypted · no metadata</TextBlock>

                <!-- Status/error message -->
                <TextBlock x:Name="AuthStatus" FontSize="11" Foreground="#FF3333"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Visibility="Collapsed"/>

                <!-- Tabs: Login / Register -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="TabLogin" Content="[LOGIN]" Grid.Column="0"
                            Style="{StaticResource TermBtn}" Click="TabLogin_Click"
                            FontSize="12" Padding="0,8"/>
                    <Button x:Name="TabRegister" Content="[NEW VAULT]" Grid.Column="1"
                            Style="{StaticResource TermBtn}" Click="TabRegister_Click"
                            FontSize="12" Padding="0,8"/>
                </Grid>

                <!-- Login form -->
                <StackPanel x:Name="LoginForm">
                    <TextBlock FontSize="10" Foreground="#555555" Margin="0,0,0,4">
                        > password (any characters, any length)
                    </TextBlock>
                    <PasswordBox x:Name="LoginPass"
                                 Background="#0C0C0C" Foreground="#00FF41"
                                 CaretBrush="#00FF41" BorderBrush="#1F1F1F"
                                 BorderThickness="1" FontFamily="Consolas" FontSize="12"
                                 Padding="8,6" Margin="0,0,0,12"
                                 KeyDown="LoginPass_KeyDown"/>
                    <TextBlock FontSize="10" Foreground="#555555" Margin="0,0,0,4">
                        > relay server url
                    </TextBlock>
                    <TextBox x:Name="LoginServerUrl" Style="{StaticResource TermInput}"
                             Margin="0,0,0,16"/>
                    <Button Content="[ UNLOCK VAULT ]" Style="{StaticResource TermBtn}"
                            FontSize="12" Padding="0,10" Click="BtnLogin_Click"
                            x:Name="BtnLogin"/>
                </StackPanel>

                <!-- Register form -->
                <StackPanel x:Name="RegisterForm" Visibility="Collapsed">
                    <TextBlock FontSize="10" Foreground="#555555" Margin="0,0,0,4">
                        > display name (visible to contacts)
                    </TextBlock>
                    <TextBox x:Name="RegName" Style="{StaticResource TermInput}"
                             Margin="0,0,0,12"/>
                    <TextBlock FontSize="10" Foreground="#555555" Margin="0,0,0,4">
                        > password (no requirements — any characters work)
                    </TextBlock>
                    <PasswordBox x:Name="RegPass"
                                 Background="#0C0C0C" Foreground="#00FF41"
                                 CaretBrush="#00FF41" BorderBrush="#1F1F1F"
                                 BorderThickness="1" FontFamily="Consolas" FontSize="12"
                                 Padding="8,6" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="RegPass2"
                                 Background="#0C0C0C" Foreground="#00FF41"
                                 CaretBrush="#00FF41" BorderBrush="#1F1F1F"
                                 BorderThickness="1" FontFamily="Consolas" FontSize="12"
                                 Padding="8,6" Margin="0,0,0,12"/>
                    <TextBlock FontSize="10" Foreground="#555555" Margin="0,0,0,4">
                        > relay server url
                    </TextBlock>
                    <TextBox x:Name="RegServerUrl" Style="{StaticResource TermInput}"
                             Margin="0,0,0,16"/>
                    <Button Content="[ CREATE VAULT ]" Style="{StaticResource TermBtn}"
                            FontSize="12" Padding="0,10" Click="BtnRegister_Click"
                            x:Name="BtnRegister"/>
                </StackPanel>

                <TextBlock x:Name="VaultStorageHintText" FontSize="9" Foreground="#333333" HorizontalAlignment="Center"
                           Margin="0,20,0,0">
                    vault stored in %APPDATA%\Cipher — no cloud, no servers, just you
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- ════════════════════════════════════════════════════ -->
        <!--  MAIN CHAT PANEL                                     -->
        <!-- ════════════════════════════════════════════════════ -->
        <Grid x:Name="ChatPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>   <!-- Header bar -->
                <RowDefinition Height="*"/>    <!-- Body -->
            </Grid.RowDefinitions>

            <!-- ── Header bar ── -->
            <Border Grid.Row="0" Background="#0E0E0E" BorderBrush="#1F1F1F" BorderThickness="0,0,0,1">
                <Grid Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status dot + app name -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="ConnDot" Text="●" FontSize="10"
                                   Foreground="#FF3333" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="HeaderBrandText" Text="CIPHER" FontSize="12" FontWeight="Bold"
                                   Foreground="#00FF41" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Active conversation name -->
                    <TextBlock x:Name="ActiveConvName" Grid.Column="1"
                               FontSize="11" Foreground="#555555"
                               VerticalAlignment="Center" Margin="16,0"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- My user ID (clickable to copy) -->
                    <Button x:Name="BtnMyId" Grid.Column="2" Style="{StaticResource TermBtn}"
                            FontSize="9" Padding="6,3" Margin="0,0,6,0"
                            Click="BtnMyId_Click" ToolTip="Click to copy your ID"/>

                    <!-- Add contact -->
                    <Button Grid.Column="3" Content="[+]" Style="{StaticResource TermBtn}"
                            FontSize="11" Padding="8,4" Margin="0,0,6,0"
                            Click="BtnAddContact_Click" ToolTip="Add contact or create group"/>

                    <!-- NUKE -->
                    <Button Grid.Column="4" Content="[☢ NUKE]" Style="{StaticResource NukeBtn}"
                            FontSize="10" Click="BtnNuke_Click"
                            ToolTip="Permanently destroy vault and wipe all data"/>
                </Grid>
            </Border>

            <!-- ── Body ── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" MinWidth="140" MaxWidth="280"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Left: contacts/groups sidebar ── -->
                <Grid Grid.Column="0" Background="#0E0E0E">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="CONVERSATIONS"
                               FontSize="9" Foreground="#444444"
                               Margin="8,8,0,0"/>

                    <!-- Virtualized contact/group list -->
                    <ListBox x:Name="ConvList" Grid.Row="1"
                             Style="{StaticResource TermList}"
                             SelectionChanged="ConvList_SelectionChanged"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             ScrollViewer.CanContentScroll="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Online indicator -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding StatusChar}"
                                               Foreground="{Binding StatusBrush}"
                                               FontSize="9" VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <!-- Name -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DisplayName}"
                                               FontSize="11" Foreground="{Binding NameBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <!-- Unread badge -->
                                    <Border Grid.Column="2"
                                            Background="#1A3A1A" CornerRadius="2"
                                            Margin="4,0,0,0"
                                            Visibility="{Binding HasUnread, Converter={StaticResource BoolVis}}">
                                        <TextBlock Text="{Binding UnreadCount}"
                                                   FontSize="9" Foreground="#00FF41"
                                                   Padding="4,1"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Typing indicator area -->
                    <TextBlock x:Name="SidebarStatus" Grid.Row="2"
                               FontSize="9" Foreground="#333333"
                               Margin="8,4" TextWrapping="Wrap"/>
                </Grid>

                <!-- ── Splitter ── -->
                <GridSplitter Grid.Column="1" Width="1"
                              Background="#1F1F1F" ResizeBehavior="PreviousAndNext"
                              HorizontalAlignment="Stretch"/>

                <!-- ── Right: message area ── -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Empty state -->
                    <TextBlock x:Name="EmptyState" Grid.Row="0"
                               Text="select a conversation" FontSize="11"
                               Foreground="#333333" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <!-- ── Message list — VIRTUALIZED ── -->
                    <!--
                        Key settings for correct lazy rendering:
                        - VirtualizingPanel.IsVirtualizing=True (only render visible items)
                        - VirtualizationMode=Recycling (recycle containers for low-end PCs)
                        - ScrollUnit=Pixel (smooth scrolling, no jumping on variable-height items)
                        - CanContentScroll=True (required for virtualization to work)
                        - HorizontalScrollBarVisibility=Disabled (never needed)
                        - DO NOT set Height=Auto on this control (breaks virtualization)
                    -->
                    <ListBox x:Name="MessageList" Grid.Row="0"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             VirtualizingPanel.CacheLengthUnit="Page"
                             VirtualizingPanel.CacheLength="1"
                             SelectionMode="Single"
                             Focusable="False"
                             Visibility="Collapsed"
                             Padding="0,4,0,0">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel VerticalAlignment="Bottom"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="IsTabStop" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <!--
                                    Each message row. Layout differs by IsMine:
                                    - Mine:  [time] [●] [name]: [content in amber]
                                    - Theirs:[time] [○] [name]: [content in green]
                                    Status indicator at end for mine.
                                -->
                                <Border Margin="8,1" Padding="4,3"
                                        Background="Transparent">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>  <!-- time -->
                                            <ColumnDefinition Width="Auto"/>  <!-- dot -->
                                            <ColumnDefinition Width="Auto"/>  <!-- name -->
                                            <ColumnDefinition Width="*"/>     <!-- content -->
                                            <ColumnDefinition Width="Auto"/>  <!-- status -->
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding TimeStr}"
                                                   Style="{StaticResource MsgTime}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding BulletChar}"
                                                   Foreground="{Binding BulletBrush}"
                                                   FontSize="9" Margin="6,0,4,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding SenderLabel}"
                                                   Foreground="{Binding NameBrush}"
                                                   FontSize="11" FontWeight="Bold"
                                                   VerticalAlignment="Top"
                                                   Margin="0,0,4,0"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Content}"
                                                   Foreground="{Binding TextBrush}"
                                                   FontSize="11" FontFamily="Consolas"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Top"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding StatusChar}"
                                                   Foreground="{Binding StatusBrush}"
                                                   FontSize="9" Margin="6,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Load-more indicator -->
                    <Border x:Name="LoadMoreBar" Grid.Row="0" Background="#0E0E0E"
                            VerticalAlignment="Top" Padding="8,4"
                            Visibility="Collapsed" Panel.ZIndex="5">
                        <TextBlock Text="▲ loading older messages..." FontSize="9"
                                   Foreground="#444444" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Typing indicator -->
                    <TextBlock x:Name="TypingIndicator" Grid.Row="1"
                               FontSize="10" Foreground="#444444"
                               Margin="12,2" Visibility="Collapsed"/>

                    <!-- Input row -->
                    <Border Grid.Row="2" Background="#0E0E0E"
                            BorderBrush="#1F1F1F" BorderThickness="0,1,0,0"
                            Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&gt; " FontSize="12"
                                       Foreground="#00882A" VerticalAlignment="Center"/>
                            <TextBox x:Name="InputBox" Grid.Column="1"
                                     Style="{StaticResource TermInput}"
                                     BorderThickness="0" Background="Transparent"
                                     FontSize="12" Padding="0,2"
                                     IsEnabled="False"
                                     KeyDown="InputBox_KeyDown"
                                     TextChanged="InputBox_TextChanged"/>
                            <Button Grid.Column="2" Content="[↵]"
                                    Style="{StaticResource TermBtn}"
                                    FontSize="12" Padding="8,4" Margin="8,0,0,0"
                                    Click="BtnSend_Click" IsEnabled="False"
                                    x:Name="BtnSend"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ════════════════════════════════════════════════════ -->
        <!--  ADD CONTACT / CREATE GROUP OVERLAY                  -->
        <!-- ════════════════════════════════════════════════════ -->
        <Grid x:Name="AddOverlay" Visibility="Collapsed" Panel.ZIndex="20"
              Background="#CC000000">
            <Border Background="#111111" BorderBrush="#1F1F1F" BorderThickness="1"
                    Width="420" MaxHeight="500"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="20">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="TabAddDm" Content="[DIRECT]" Grid.Column="0"
                                Style="{StaticResource TermBtn}" Click="TabAddDm_Click"/>
                        <Button x:Name="TabAddGroup" Content="[GROUP]" Grid.Column="1"
                                Style="{StaticResource TermBtn}" Click="TabAddGroup_Click"/>
                    </Grid>

                    <!-- Add DM contact -->
                    <StackPanel x:Name="AddDmForm">
                        <TextBlock FontSize="10" Foreground="#555555" Margin="0,0,0,4">
                            > contact's user id
                        </TextBlock>
                        <TextBox x:Name="AddContactId" Style="{StaticResource TermInput}"
                                 Margin="0,0,0,8"/>
                        <TextBlock FontSize="10" Foreground="#555555" Margin="0,0,0,4">
                            > display name (local only)
                        </TextBlock>
                        <TextBox x:Name="AddContactName" Style="{StaticResource TermInput}"
                                 Margin="0,0,0,16"/>
                        <TextBlock x:Name="AddStatus" FontSize="10" Foreground="#FF3333"
                                   Margin="0,0,0,8" TextWrapping="Wrap" Visibility="Collapsed"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="[ ADD ]" Style="{StaticResource TermBtn}"
                                    Click="BtnConfirmAdd_Click"/>
                            <Button Grid.Column="1" Content="[X]" Style="{StaticResource TermBtn}"
                                    Margin="8,0,0,0" Click="BtnCloseOverlay_Click"/>
                        </Grid>
                    </StackPanel>

                    <!-- Create group -->
                    <StackPanel x:Name="AddGroupForm" Visibility="Collapsed">
                        <TextBlock FontSize="10" Foreground="#555555" Margin="0,0,0,4">
                            > group name
                        </TextBlock>
                        <TextBox x:Name="NewGroupName" Style="{StaticResource TermInput}"
                                 Margin="0,0,0,8"/>
                        <TextBlock FontSize="10" Foreground="#555555" Margin="0,0,0,4">
                            > add member user ids (one per line)
                        </TextBlock>
                        <TextBox x:Name="GroupMemberIds" Style="{StaticResource TermInput}"
                                 Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="[ CREATE GROUP ]" Style="{StaticResource TermBtn}"
                                    Click="BtnCreateGroup_Click"/>
                            <Button Grid.Column="1" Content="[X]" Style="{StaticResource TermBtn}"
                                    Margin="8,0,0,0" Click="BtnCloseOverlay_Click"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════ -->
        <!--  NUKE CONFIRMATION OVERLAY                           -->
        <!-- ════════════════════════════════════════════════════ -->
        <Grid x:Name="NukeOverlay" Visibility="Collapsed" Panel.ZIndex="30"
              Background="#DD000000">
            <Border Background="#0A0000" BorderBrush="#441111" BorderThickness="1"
                    Width="400" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="☢ VAULT NUKE" FontSize="14" FontWeight="Bold"
                               Foreground="#FF3333" Margin="0,0,0,12"/>
                    <TextBlock FontSize="10" Foreground="#888888" TextWrapping="Wrap"
                               Margin="0,0,0,16">
This will:  overwrite your vault 3x with random data · delete all messages
· delete all contacts · send a NUKE warning to all contacts · log you out

THIS CANNOT BE UNDONE.
                    </TextBlock>
                    <TextBlock FontSize="10" Foreground="#555555" Margin="0,0,0,4">
                        > type NUKE to confirm
                    </TextBlock>
                    <TextBox x:Name="NukeConfirm" Style="{StaticResource TermInput}"
                             Foreground="#FF3333" CaretBrush="#FF3333"
                             Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Content="[ DETONATE ]" Style="{StaticResource NukeBtn}"
                                Click="BtnConfirmNuke_Click" FontSize="12" Padding="0,8"/>
                        <Button Grid.Column="1" Content="[ CANCEL ]"
                                Style="{StaticResource TermBtn}"
                                Margin="8,0,0,0" FontSize="12" Padding="0,8"
                                Click="BtnCancelNuke_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
