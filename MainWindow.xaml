<Window x:Class="Cipher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CIPHER"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        Icon="Assets/48x48.ico"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="{StaticResource UiFont}"
        Foreground="{StaticResource White}"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
        <Style x:Key="MsgTime" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="FontFamily" Value="{StaticResource Mono}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Margin" Value="0,0,8,1" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid x:Name="AuthPanel" Panel.ZIndex="10">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#070F19" Offset="0" />
                    <GradientStop Color="#14263C" Offset="0.6" />
                    <GradientStop Color="#0A1320" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <Border Width="480"
                    Padding="36"
                    CornerRadius="24"
                    Background="#CC15253A"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1.2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="LegacyLogo"
                               Visibility="Collapsed"
                               FontFamily="{StaticResource Mono}"
                               FontSize="11"
                               Foreground="{StaticResource Green}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,16"><![CDATA[  ██████╗██╗██████╗ ██╗  ██╗███████╗██████╗
 ██╔════╝██║██╔══██╗██║  ██║██╔════╝██╔══██╗
 ██║     ██║██████╔╝███████║█████╗  ██████╔╝
 ██║     ██║██╔═══╝ ██╔══██║██╔══╝  ██╔══██╗
 ╚██████╗██║██║     ██║  ██║███████╗██║  ██║
  ╚═════╝╚═╝╚═╝     ╚═╝  ╚═╝╚══════╝╚═╝  ╚═╝]]></TextBlock>
                    <TextBlock x:Name="AuthBrandTitle"
                               Text="CIPHER"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource White}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="静 · private relay chat for trusted contacts"
                               Margin="0,8,0,6"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource Green}"
                               FontSize="14"
                               FontWeight="Medium" />
                    <TextBlock Text="Clean layout, local vault, simple relay."
                               Margin="0,0,0,24"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource Muted}"
                               FontSize="12" />
                    <TextBlock x:Name="AuthStatus"
                               Visibility="Collapsed"
                               Margin="0,0,0,16"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource Red}" />
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="TabLogin"
                                Grid.Column="0"
                                Margin="0,0,8,0"
                                Padding="0,10"
                                FontSize="13"
                                Content="开 Unlock"
                                Style="{StaticResource TermBtn}"
                                Click="TabLogin_Click" />
                        <Button x:Name="TabRegister"
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="0,10"
                                FontSize="13"
                                Content="新 Vault"
                                Style="{StaticResource TermBtn}"
                                Click="TabRegister_Click" />
                    </Grid>
                    <StackPanel x:Name="LoginForm">
                        <TextBlock Text="Password" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <PasswordBox x:Name="LoginPass" Style="{StaticResource TermPasswordInput}" Margin="0,0,0,14" KeyDown="LoginPass_KeyDown" />
                        <TextBlock Text="云 Relay URL" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="LoginServerUrl" Style="{StaticResource TermInput}" Margin="0,0,0,4" />
                        <TextBlock Text="Use HTTPS for real relays. HTTP is only for localhost development."
                                   Foreground="{StaticResource Dim}" FontSize="11" Margin="0,0,0,14" TextWrapping="Wrap" />
                        <CheckBox x:Name="LoginRememberSession" Content="Remember this device" IsChecked="False" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,18" />
                        <Button x:Name="BtnLogin" Content="启 Open Vault" Style="{StaticResource TermBtn}" FontSize="13" Padding="0,12" Click="BtnLogin_Click" />
                    </StackPanel>
                    <StackPanel x:Name="RegisterForm" Visibility="Collapsed">
                        <TextBlock Text="Display name" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="RegName" Style="{StaticResource TermInput}" Margin="0,0,0,14" />
                        <TextBlock Text="Password" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <PasswordBox x:Name="RegPass" Style="{StaticResource TermPasswordInput}" Margin="0,0,0,8" />
                        <PasswordBox x:Name="RegPass2" Style="{StaticResource TermPasswordInput}" Margin="0,0,0,14" />
                        <TextBlock Text="云 Relay URL" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="RegServerUrl" Style="{StaticResource TermInput}" Margin="0,0,0,4" />
                        <TextBlock Text="Use the same relay as your contact so offline delivery works reliably."
                                   Foreground="{StaticResource Dim}" FontSize="11" Margin="0,0,0,14" TextWrapping="Wrap" />
                        <CheckBox x:Name="RegisterRememberSession" Content="Remember this device" IsChecked="False" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,18" />
                        <Button x:Name="BtnRegister" Content="筑 Create Vault" Style="{StaticResource TermBtn}" FontSize="13" Padding="0,12" Click="BtnRegister_Click" />
                    </StackPanel>
                    <TextBlock x:Name="VaultStorageHintText"
                               Margin="0,20,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource Dim}"
                               FontSize="11"
                               TextAlignment="Center"
                               TextWrapping="Wrap">vault stored in %APPDATA%\Cipher</TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="ChatPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="14,12"
                    CornerRadius="18"
                    Background="#B915273E"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1.2"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="ConnDot" Text="●" FontSize="12" Foreground="{StaticResource Red}" Margin="0,0,8,0" />
                        <StackPanel>
                            <TextBlock x:Name="HeaderBrandText" Text="CIPHER" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource White}" />
                            <TextBlock x:Name="ConnStatusText" Text="offline" FontSize="12" Foreground="{StaticResource Muted}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="ActiveConvName"
                               Grid.Column="1"
                               Margin="14,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="{StaticResource Muted}"
                               Text="No conversation selected"
                               TextTrimming="CharacterEllipsis" />
                    <Button x:Name="BtnSecurityReview" Grid.Column="2" Content="Verify" Margin="0,0,8,0" Padding="12,6" FontSize="12" Style="{StaticResource TermBtn}" Click="BtnSecurityReview_Click" Visibility="Collapsed" />
                    <Button x:Name="BtnMyId" Grid.Column="3" Margin="0,0,8,0" Padding="12,6" FontSize="12" Style="{StaticResource InfoBtn}" Click="BtnMyId_Click" />
                    <Button x:Name="BtnOpenAddOverlay" Grid.Column="4" Content="Add Friend" Margin="0,0,8,0" Padding="12,6" FontSize="12" Style="{StaticResource AccentBtn}" Click="BtnAddContact_Click" Visibility="Collapsed" />
                    <Button x:Name="BtnGroupInvite" Grid.Column="5" Content="Invite Members" Margin="0,0,8,0" Padding="12,6" FontSize="12" Style="{StaticResource GroupBtn}" Click="BtnGroupInvite_Click" Visibility="Collapsed" />
                    <Button x:Name="BtnSettings" Grid.Column="6" Content="System" Margin="0,0,8,0" Padding="12,6" FontSize="12" Style="{StaticResource InfoBtn}" Click="BtnSettings_Click" />
                    <Button x:Name="BtnOpenNukeOverlay" Grid.Column="7" Content="Nuke" Padding="12,6" FontSize="12" Style="{StaticResource NukeBtn}" Click="BtnNuke_Click" />
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="278" MinWidth="228" MaxWidth="348" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        CornerRadius="18"
                        Background="#B9142438"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1.2"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="月 Conversations" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource White}" />
                                <TextBlock Text="Direct contacts and groups" FontSize="11" Foreground="{StaticResource Muted}" />
                            </StackPanel>
                            <WrapPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <Button x:Name="BtnSidebarAddFriend" Content="Add Friend" Padding="10,6" FontSize="11" Style="{StaticResource AccentBtn}" Click="BtnAddContact_Click" ToolTip="Add direct contact" />
                                <Button x:Name="BtnQuickNewGroup" Content="New Group" Padding="10,6" FontSize="11" Margin="8,0,0,0" Style="{StaticResource GroupBtn}" Click="BtnQuickNewGroup_Click" ToolTip="Create a new group" />
                                <Button x:Name="BtnSideGroupInvite" Content="Invite" Padding="10,6" FontSize="11" Margin="8,0,0,0" Style="{StaticResource InfoBtn}" Click="BtnGroupInvite_Click" ToolTip="Invite members to selected group" Visibility="Collapsed" />
                            </WrapPanel>
                        </Grid>
                        <ListBox x:Name="ConvList" Grid.Row="1" Style="{StaticResource TermList}" SelectionChanged="ConvList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding StatusChar}" Foreground="{Binding StatusBrush}" FontFamily="{StaticResource Mono}" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayName}" Foreground="{Binding NameBrush}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Id}" Foreground="{StaticResource Dim}" FontFamily="{StaticResource Mono}" FontSize="10" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Border Grid.Column="2" CornerRadius="10" Background="#3A2A17" BorderBrush="{StaticResource GoldAccent}" BorderThickness="0.8" Padding="8,3" Margin="8,0,0,0" Visibility="{Binding HasUnread, Converter={StaticResource BoolVis}}">
                                            <TextBlock Text="{Binding UnreadCount}" Foreground="{StaticResource White}" FontSize="11" FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Row="2" Margin="0,10,0,0" Padding="10" CornerRadius="12" Background="#9E1A2A40" BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <TextBlock x:Name="SidebarStatus" FontSize="11" Foreground="{StaticResource Muted}" TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" Background="Transparent" ResizeBehavior="PreviousAndNext" />

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="18" Background="#B916273E" BorderBrush="{StaticResource Border}" BorderThickness="1.2" Padding="12">
                        <Grid>
                            <TextBlock x:Name="EmptyState" Text="山 Pick a conversation to start chatting." FontSize="18" Foreground="{StaticResource Muted}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <ListBox x:Name="MessageList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0,6,0,0"
                                     Visibility="Collapsed"
                                     SelectionMode="Single"
                                     Focusable="False"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     VirtualizingPanel.ScrollUnit="Pixel"
                                     VirtualizingPanel.CacheLengthUnit="Page"
                                     VirtualizingPanel.CacheLength="1">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel VerticalAlignment="Bottom" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="IsTabStop" Value="False" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5">
                                            <Border x:Name="MessageBubble"
                                                    Padding="12,10"
                                                    CornerRadius="14"
                                                    BorderBrush="{Binding BubbleBorderBrush}"
                                                    BorderThickness="0.9"
                                                    Background="{Binding BubbleBackground}"
                                                    HorizontalAlignment="Left"
                                                    MaxWidth="560">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <DockPanel Grid.Row="0" LastChildFill="False">
                                                        <TextBlock Text="{Binding BulletChar}"
                                                                   Foreground="{Binding BulletBrush}"
                                                                   FontFamily="{StaticResource Mono}"
                                                                   FontSize="11"
                                                                   Margin="0,0,8,0"
                                                                   DockPanel.Dock="Left"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding SenderLabel}"
                                                                   Foreground="{Binding NameBrush}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   DockPanel.Dock="Left" />
                                                        <TextBlock Text="{Binding TimeStr}"
                                                                   Style="{StaticResource MsgTime}"
                                                                   Margin="12,0,0,0"
                                                                   DockPanel.Dock="Right" />
                                                    </DockPanel>
                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding Content}"
                                                               Margin="0,6,0,0"
                                                               Foreground="{Binding TextBrush}"
                                                               FontFamily="{StaticResource UiFont}"
                                                               FontSize="15"
                                                               TextWrapping="Wrap" />
                                                    <StackPanel Grid.Row="2"
                                                                Margin="0,8,0,0"
                                                                HorizontalAlignment="Right"
                                                                Visibility="{Binding IsMine, Converter={StaticResource BoolVis}}">
                                                        <TextBlock Text="{Binding DeliveryText}"
                                                                   Foreground="{Binding DeliveryBrush}"
                                                                   FontFamily="{StaticResource Mono}"
                                                                   FontSize="11"
                                                                   HorizontalAlignment="Right"
                                                                   Visibility="{Binding HasDeliveryText, Converter={StaticResource BoolVis}}" />
                                                        <ItemsControl ItemsSource="{Binding SeenBy}"
                                                                      HorizontalAlignment="Right"
                                                                      Visibility="{Binding HasSeenBy, Converter={StaticResource BoolVis}}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel HorizontalAlignment="Right" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Margin="0,4,4,0"
                                                                            Padding="8,2"
                                                                            CornerRadius="9"
                                                                            Background="#23344C"
                                                                            BorderBrush="{Binding Color}"
                                                                            BorderThickness="0.9">
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   Foreground="{Binding Color}"
                                                                                   FontSize="10"
                                                                                   FontWeight="SemiBold" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Border x:Name="LoadMoreBar"
                                    Visibility="Collapsed"
                                    Panel.ZIndex="5"
                                    Padding="10,8"
                                    CornerRadius="12"
                                    Background="#DC152235"
                                    BorderBrush="{StaticResource Border}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Margin="0,6,0,0">
                                <TextBlock Text="Loading older messages..." FontSize="11" Foreground="{StaticResource Muted}" />
                            </Border>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="TypingIndicator" Grid.Row="1" Margin="12,8,12,0" Visibility="Collapsed" FontSize="11" Foreground="{StaticResource Muted}" />
                    <Border x:Name="ComposerPanel" Grid.Row="2" Margin="0,12,0,0" Padding="12" CornerRadius="18" Background="#D9182435" BorderBrush="{StaticResource Border}" BorderThickness="1.2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InputBox" Grid.Column="0" Style="{StaticResource TermInput}" Background="#152336" FontSize="14" MinHeight="46" VerticalContentAlignment="Center" IsEnabled="False" KeyDown="InputBox_KeyDown" TextChanged="InputBox_TextChanged" ToolTip="Enter to send. Shift+Enter for a new line." />
                            <Button x:Name="BtnEmojiPicker" Grid.Column="1" Margin="10,0,0,0" Padding="10,10" FontSize="16" Content="🙂" Style="{StaticResource TermBtn}" Click="BtnEmojiPicker_Click" ToolTip="Open OpenMoji picker" />
                            <Button x:Name="BtnSend" Grid.Column="2" Margin="10,0,0,0" Padding="18,10" FontSize="13" Content="Send" IsEnabled="False" Style="{StaticResource AccentBtn}" Click="BtnSend_Click" />
                            <Popup x:Name="EmojiPopup" Placement="Top" PlacementTarget="{Binding ElementName=BtnEmojiPicker}" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Padding="10" Width="320" Height="220" CornerRadius="12" Background="#F0141F2C" BorderBrush="{StaticResource Border}" BorderThickness="1.2">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <WrapPanel x:Name="EmojiPanel" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid x:Name="AddOverlay" Visibility="Collapsed" Panel.ZIndex="20" Background="#B3000000">
            <Border Width="460" MaxHeight="560" Padding="24" CornerRadius="22" Background="#F915273E" BorderBrush="{StaticResource Border}" BorderThickness="1.2" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="结 Add contact or create a group" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource White}" Margin="0,0,0,18" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="TabAddDm" Grid.Column="0" Margin="0,0,8,0" Content="月 Direct" Style="{StaticResource TermBtn}" Click="TabAddDm_Click" />
                        <Button x:Name="TabAddGroup" Grid.Column="1" Margin="8,0,0,0" Content="山 Group" Style="{StaticResource TermBtn}" Click="TabAddGroup_Click" />
                    </Grid>
                    <Border x:Name="AddStatusPanel" Visibility="Collapsed" Margin="0,0,0,12" Padding="10,8" Background="#1A2432" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10">
                        <TextBlock x:Name="AddStatus" Visibility="Collapsed" FontSize="12" Foreground="{StaticResource Red}" TextWrapping="Wrap" />
                    </Border>
                    <StackPanel x:Name="AddDmForm">
                        <TextBlock Text="Contact user ID" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="AddContactId" Style="{StaticResource TermInput}" Margin="0,0,0,12" />
                        <TextBlock Text="Display name" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="AddContactName" Style="{StaticResource TermInput}" Margin="0,0,0,18" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnConfirmAddContact" Content="Save Friend" Style="{StaticResource AccentBtn}" Click="BtnConfirmAdd_Click" />
                            <Button x:Name="BtnCloseAddOverlay" Grid.Column="1" Margin="10,0,0,0" Content="Close" Style="{StaticResource TermBtn}" Click="BtnCloseOverlay_Click" />
                        </Grid>
                    </StackPanel>
                    <StackPanel x:Name="AddGroupForm" Visibility="Collapsed">
                        <TextBlock x:Name="GroupModeHint" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap" />
                        <TextBlock Text="Group name" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="NewGroupName" Style="{StaticResource TermInput}" Margin="0,0,0,12" />
                        <TextBlock Text="Member user IDs (one per line, optional)" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="GroupMemberIds" Height="110" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Style="{StaticResource TermInput}" Margin="0,0,0,18" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnConfirmCreateGroup" Content="Create group" Style="{StaticResource GroupBtn}" Click="BtnCreateGroup_Click" />
                            <Button x:Name="BtnCloseGroupOverlay" Grid.Column="1" Margin="10,0,0,0" Content="Close" Style="{StaticResource TermBtn}" Click="BtnCloseOverlay_Click" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="SettingsOverlay" Visibility="Collapsed" Panel.ZIndex="25" Background="#B3000000">
            <Border Width="500" Padding="24" CornerRadius="22" Background="#F915273E" BorderBrush="{StaticResource Border}" BorderThickness="1.2" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="卷 System" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource White}" Margin="0,0,0,18" />
                    <TextBlock Text="Version" Foreground="{StaticResource Muted}" FontSize="12" />
                    <TextBlock x:Name="SettingsVersionText" Margin="0,4,0,14" Foreground="{StaticResource White}" FontSize="13" />
                    <TextBlock Text="Update status" Foreground="{StaticResource Muted}" FontSize="12" />
                    <TextBlock x:Name="SettingsUpdateStatusText" Margin="0,4,0,8" Foreground="{StaticResource White}" FontSize="12" TextWrapping="Wrap" />
                    <ProgressBar x:Name="UpdateProgressBar" Height="8" Minimum="0" Maximum="100" Margin="0,0,0,14" Visibility="Collapsed" />
                    <TextBlock Text="Diagnostics" Foreground="{StaticResource Muted}" FontSize="12" />
                    <TextBlock x:Name="SettingsDiagnosticsText" Margin="0,4,0,18" Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" />
                    <UniformGrid Columns="2" Margin="0,0,0,14">
                        <Button x:Name="BtnCheckUpdates" Content="Check updates" Style="{StaticResource InfoBtn}" Margin="0,0,10,10" Click="BtnCheckUpdates_Click" />
                        <Button x:Name="BtnRestartToUpdate" Content="Restart to update" Style="{StaticResource GroupBtn}" Margin="0,0,0,10" Click="BtnRestartToUpdate_Click" Visibility="Collapsed" />
                        <Button x:Name="BtnOpenLogs" Content="Open logs" Style="{StaticResource InfoBtn}" Margin="0,0,10,0" Click="BtnOpenLogs_Click" />
                        <Button x:Name="BtnOpenData" Content="Open data" Style="{StaticResource AccentBtn}" Click="BtnOpenData_Click" />
                    </UniformGrid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnExportDiagnostics" Content="Export diagnostics" Style="{StaticResource InfoBtn}" Click="BtnExportDiagnostics_Click" />
                        <Button Grid.Column="1" Margin="10,0,0,0" Content="Close" Style="{StaticResource TermBtn}" Click="BtnCloseSettings_Click" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="NukeOverlay" Visibility="Collapsed" Panel.ZIndex="30" Background="#C8000000">
            <Border Width="430" Padding="24" CornerRadius="22" Background="#F9161013" BorderBrush="#6F2D39" BorderThickness="1.2" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="焚 Vault nuke" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource Red}" Margin="0,0,0,12" />
                    <TextBlock Margin="0,0,0,16" Foreground="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap">This permanently destroys the vault, local history, contacts, and session state. Type NUKE to confirm.</TextBlock>
                    <TextBlock Text="Confirmation" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                    <TextBox x:Name="NukeConfirm" Style="{StaticResource TermInput}" Margin="0,0,0,18" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnConfirmNuke" Grid.Column="0" Content="Detonate" Style="{StaticResource NukeBtn}" Click="BtnConfirmNuke_Click" />
                        <Button x:Name="BtnCancelNuke" Grid.Column="1" Margin="10,0,0,0" Content="Cancel" Style="{StaticResource TermBtn}" Click="BtnCancelNuke_Click" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

