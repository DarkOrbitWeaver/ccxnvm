<Window x:Class="Cipher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Cipher"
        Title="ZLABO"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        Icon="Assets/48x48.ico"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="{StaticResource UiFont}"
        Foreground="{StaticResource White}"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="MainWindow_PreviewKeyDown"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
        <Style x:Key="MsgTime" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="FontFamily" Value="{StaticResource Mono}" />
            <Setter Property="FontSize" Value="{DynamicResource ChatMetaFontSize}" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Margin" Value="0,0,8,1" />
        </Style>
        <DataTemplate DataType="{x:Type local:UnreadSeparatorViewModel}">
            <Grid Margin="18,10,18,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Height="1"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        Background="{DynamicResource GlassBorder}" />
                <Border Grid.Column="1"
                        Padding="10,3"
                        CornerRadius="10"
                        Background="#14000000"
                        BorderBrush="{DynamicResource GlassBorder}"
                        BorderThickness="1">
                    <TextBlock Text="{Binding Label}"
                               FontFamily="{StaticResource Mono}"
                               FontSize="10"
                               Foreground="{DynamicResource TealAccent}" />
                </Border>
                <Border Grid.Column="2"
                        Height="1"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        Background="{DynamicResource GlassBorder}" />
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:MessageViewModel}">
            <Grid Margin="0,5">
                <Border x:Name="MessageBubble"
                        Padding="12,8"
                        CornerRadius="13"
                        BorderBrush="{Binding BubbleBorderBrush}"
                        BorderThickness="1"
                        Background="{Binding BubbleBackground}"
                        HorizontalAlignment="Left"
                        MaxWidth="520">
                    <Border.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                     Background="{StaticResource GlassOverlay}"
                                     BorderBrush="{DynamicResource GlassBorder}"
                                     BorderThickness="1">
                            <MenuItem Header="Copy message"
                                      Click="CopyMessageMenuItem_Click" />
                        </ContextMenu>
                    </Border.ContextMenu>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" LastChildFill="False">
                            <TextBlock Text="{Binding SenderLabel}"
                                       Foreground="{Binding SenderColorBrush}"
                                       FontSize="{DynamicResource ChatSenderFontSize}"
                                       FontWeight="SemiBold"
                                       DockPanel.Dock="Left" />
                            <TextBlock Text="{Binding TimeStr}"
                                       Style="{StaticResource MsgTime}"
                                       Margin="12,0,0,0"
                                       DockPanel.Dock="Right" />
                        </DockPanel>
                        <RichTextBox Grid.Row="1"
                                     Margin="0,6,0,0"
                                     IsReadOnly="True"
                                     IsDocumentEnabled="False"
                                     IsTabStop="False"
                                     Focusable="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     FontFamily="{StaticResource ChatFont}"
                                     FontSize="{DynamicResource ChatMessageFontSize}"
                                     ContextMenuService.IsEnabled="False"
                                     local:MsgBodyHelper.Content="{Binding}"
                                     local:MsgBodyHelper.RenderFontSize="{DynamicResource ChatMessageFontSize}" />
                        <StackPanel Grid.Row="2"
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Right"
                                    Visibility="{Binding IsMine, Converter={StaticResource BoolVis}}">
                            <TextBlock Text="{Binding DeliveryText}"
                                       Foreground="{Binding DeliveryBrush}"
                                       FontFamily="{StaticResource Mono}"
                                       FontSize="{DynamicResource ChatMetaFontSize}"
                                       HorizontalAlignment="Right"
                                       Visibility="{Binding HasDeliveryText, Converter={StaticResource BoolVis}}" />
                            <ItemsControl ItemsSource="{Binding SeenBy}"
                                          HorizontalAlignment="Right"
                                          Visibility="{Binding HasSeenBy, Converter={StaticResource BoolVis}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Right" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,4,4,0"
                                                Padding="8,2"
                                                CornerRadius="9"
                                                Background="{StaticResource SeenChipBg}"
                                                BorderBrush="{Binding Color}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{Binding Color}"
                                                       FontSize="{DynamicResource ChatMetaFontSize}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="18">
        <Grid x:Name="AuthPanel" Panel.ZIndex="10">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#070F19" Offset="0" />
                    <GradientStop Color="#14263C" Offset="0.6" />
                    <GradientStop Color="#0A1320" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <Border Width="480"
                    Padding="36"
                    CornerRadius="24"
                    Background="{StaticResource GlassOverlay}"
                    BorderBrush="{DynamicResource GlassBorder}"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="LegacyLogo"
                               Visibility="Collapsed"
                               FontFamily="{StaticResource Mono}"
                               FontSize="11"
                               Foreground="{StaticResource Green}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,16"><![CDATA[  ██████╗██╗██████╗ ██╗  ██╗███████╗██████╗
 ██╔════╝██║██╔══██╗██║  ██║██╔════╝██╔══██╗
 ██║     ██║██████╔╝███████║█████╗  ██████╔╝
 ██║     ██║██╔═══╝ ██╔══██║██╔══╝  ██╔══██╗
 ╚██████╗██║██║     ██║  ██║███████╗██║  ██║
  ╚═════╝╚═╝╚═╝     ╚═╝  ╚═╝╚══════╝╚═╝  ╚═╝]]></TextBlock>
                    <TextBlock x:Name="AuthBrandTitle"
                               Text="ZLABO"
                               FontSize="34"
                               FontFamily="{StaticResource DisplayFont}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource White}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="静 · private relay chat for trusted contacts"
                               Margin="0,8,0,6"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource Green}"
                               FontSize="14"
                               FontWeight="Medium" />
                    <TextBlock Text="Clean layout, local vault, simple relay."
                               Margin="0,0,0,24"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource Muted}"
                               FontSize="12" />
                    <TextBlock x:Name="AuthStatus"
                               Visibility="Collapsed"
                               Margin="0,0,0,16"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource Red}" />
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="TabLogin"
                                Grid.Column="0"
                                Margin="0,0,8,0"
                                Padding="0,10"
                                FontSize="13"
                                Content="Unlock"
                                Style="{StaticResource TermBtn}"
                                Click="TabLogin_Click" />
                        <Button x:Name="TabRegister"
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="0,10"
                                FontSize="13"
                                Content="New Vault"
                                Style="{StaticResource TermBtn}"
                                Click="TabRegister_Click" />
                    </Grid>
                    <StackPanel x:Name="LoginForm">
                        <TextBlock Text="Password" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <PasswordBox x:Name="LoginPass" Style="{StaticResource TermPasswordInput}" Margin="0,0,0,14" KeyDown="LoginPass_KeyDown" />
                        <TextBlock Text="Relay URL" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="LoginServerUrl" Style="{StaticResource TermInput}" Margin="0,0,0,4" />
                        <TextBlock Text="Use HTTPS for real relays. HTTP is only for localhost development."
                                   Foreground="{StaticResource Dim}" FontSize="11" Margin="0,0,0,14" TextWrapping="Wrap" />
                        <CheckBox x:Name="LoginRememberSession" Content="Remember this device" IsChecked="False" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,18" />
                        <Button x:Name="BtnLogin" Content="Open Vault" Style="{StaticResource AccentBtn}" FontSize="13" Padding="0,12" Click="BtnLogin_Click" />
                    </StackPanel>
                    <StackPanel x:Name="RegisterForm" Visibility="Collapsed">
                        <TextBlock Text="Display name" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="RegName" Style="{StaticResource TermInput}" Margin="0,0,0,14" />
                        <TextBlock Text="Password" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <PasswordBox x:Name="RegPass" Style="{StaticResource TermPasswordInput}" Margin="0,0,0,8" />
                        <TextBlock Text="Confirm password" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <PasswordBox x:Name="RegPass2" Style="{StaticResource TermPasswordInput}" Margin="0,0,0,14" />
                        <TextBlock Text="Relay URL" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="RegServerUrl" Style="{StaticResource TermInput}" Margin="0,0,0,4" />
                        <TextBlock Text="Use the same relay as your contact so offline delivery works reliably."
                                   Foreground="{StaticResource Dim}" FontSize="11" Margin="0,0,0,14" TextWrapping="Wrap" />
                        <CheckBox x:Name="RegisterRememberSession" Content="Remember this device" IsChecked="False" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,18" />
                        <Button x:Name="BtnRegister" Content="Create Vault" Style="{StaticResource AccentBtn}" FontSize="13" Padding="0,12" Click="BtnRegister_Click" />
                    </StackPanel>
                    <TextBlock x:Name="VaultStorageHintText"
                               Margin="0,20,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource Dim}"
                               FontSize="11"
                               TextAlignment="Center"
                               TextWrapping="Wrap">vault stored in %APPDATA%\Cipher</TextBlock>
                    </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="ChatPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="14,12"
                    CornerRadius="18"
                    Background="{StaticResource GlassPanel}"
                    BorderBrush="{DynamicResource GlassBorder}"
                    BorderThickness="1"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="ConnDot" Text="●" FontSize="12" Foreground="{StaticResource Red}" Margin="0,0,8,0" />
                        <StackPanel>
                            <TextBlock x:Name="HeaderBrandText" Text="ZLABO" FontSize="15" FontFamily="{StaticResource DisplayFont}" FontWeight="Bold" Foreground="{StaticResource White}" />
                            <TextBlock x:Name="ConnStatusText" Text="offline" FontSize="12" Foreground="{StaticResource Muted}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="ActiveConvName"
                               Grid.Column="1"
                               Margin="14,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="{StaticResource Muted}"
                               Text="No conversation selected"
                               TextTrimming="CharacterEllipsis" />
                    <Button x:Name="BtnSecurityReview" Grid.Column="2" Content="Verify" Margin="0,0,8,0" Padding="12,6" FontSize="12" Style="{StaticResource TermBtn}" Click="BtnSecurityReview_Click" Visibility="Collapsed" />
                    <Button x:Name="BtnMyId" Grid.Column="3" Margin="0,0,8,0" Padding="12,6" FontSize="12" Style="{StaticResource InfoBtn}" Click="BtnMyId_Click" />
                    <Button x:Name="BtnOpenAddOverlay" Grid.Column="4" Content="Add Friend" Margin="0,0,8,0" Padding="12,6" FontSize="12" Style="{StaticResource AccentBtn}" Click="BtnAddContact_Click" Visibility="Collapsed" />
                    <Button x:Name="BtnGroupInvite" Grid.Column="5" Content="Invite Members" Margin="0,0,8,0" Padding="12,6" FontSize="12" Style="{StaticResource GroupBtn}" Click="BtnGroupInvite_Click" Visibility="Collapsed" />
                    <Button x:Name="BtnGroupMenu" Grid.Column="6" Content="..." Margin="0,0,8,0" Padding="12,6" FontSize="13" Style="{StaticResource InfoBtn}" Click="BtnGroupMenu_Click" Visibility="Collapsed" />
                    <Button x:Name="BtnMuteConversation" Grid.Column="7" Content="Mute" Margin="0,0,8,0" Padding="12,6" FontSize="12" Style="{StaticResource InfoBtn}" Click="BtnMuteConversation_Click" Visibility="Collapsed" />
                    <Button x:Name="BtnSettings" Grid.Column="8" Content="System" Margin="0,0,8,0" Padding="12,6" FontSize="12" Style="{StaticResource InfoBtn}" Click="BtnSettings_Click" />
                    <Popup x:Name="GroupMenuPopup"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=BtnGroupMenu}"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Width="320"
                                Padding="16"
                                CornerRadius="16"
                                Background="{StaticResource GlassOverlay}"
                                BorderBrush="{DynamicResource GlassBorder}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="GroupMenuTitleText"
                                           Text="Group"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource White}" />
                                <TextBlock x:Name="GroupMenuOwnerText"
                                           Margin="0,6,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="GroupMenuMembersText"
                                           Margin="0,8,0,14"
                                           FontSize="12"
                                           Foreground="{StaticResource White}"
                                           TextWrapping="Wrap" />
                                <WrapPanel>
                                    <Button x:Name="BtnGroupMenuInvite"
                                            Content="Invite"
                                            Margin="0,0,8,8"
                                            Style="{StaticResource AccentBtn}"
                                            Click="BtnGroupInvite_Click" />
                                    <Button x:Name="BtnGroupMenuLeave"
                                            Content="Leave group"
                                            Margin="0,0,8,8"
                                            Style="{StaticResource InfoBtn}"
                                            Click="BtnLeaveGroup_Click" />
                                    <Button x:Name="BtnGroupMenuDelete"
                                            Content="Delete group"
                                            Margin="0,0,8,8"
                                            Style="{StaticResource NukeBtn}"
                                            Click="BtnDeleteGroup_Click"
                                            Visibility="Collapsed" />
                                    <Button Content="Close"
                                            Margin="0,0,0,8"
                                            Style="{StaticResource TermBtn}"
                                            Click="BtnCloseGroupMenu_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="278" MinWidth="228" MaxWidth="348" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        CornerRadius="18"
                        Background="{StaticResource GlassPanel}"
                        BorderBrush="{DynamicResource GlassBorder}"
                        BorderThickness="1"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="聊 Conversations" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource White}" />
                                <TextBlock Text="Direct contacts and groups" FontSize="12" Foreground="{StaticResource Muted}" Margin="0,2,0,0" />
                            </StackPanel>
                            <Border Grid.Row="1"
                                    Margin="0,12,0,0"
                                    Padding="10"
                                    CornerRadius="14"
                                    Background="#14000000"
                                    BorderBrush="{DynamicResource GlassBorder}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="BtnSidebarAddFriend" Content="Add Friend" Padding="12,7" FontSize="12" Style="{StaticResource AccentBtn}" Click="BtnAddContact_Click" ToolTip="Add direct contact" />
                                    <Button x:Name="BtnQuickNewGroup" Content="New Group" Padding="12,7" FontSize="12" Margin="10,0,0,0" Style="{StaticResource GroupBtn}" Click="BtnQuickNewGroup_Click" ToolTip="Create a new group" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <ListBox x:Name="ConvList" Grid.Row="1" Style="{StaticResource TermList}" SelectionChanged="ConvList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding ConversationGlyph}"
                                                   Foreground="{Binding ConversationGlyphBrush}"
                                                   FontFamily="{Binding ConversationGlyphFontFamily}"
                                                   FontSize="{Binding ConversationGlyphFontSize}"
                                                   Width="16"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Margin="0,1,10,0" />
                                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{Binding NameBrush}"
                                                           FontSize="{DynamicResource ConversationNameFontSize}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           DockPanel.Dock="Left" />
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                    <Border Margin="8,0,0,0"
                                                            Padding="6,2"
                                                            CornerRadius="8"
                                                            Background="#20303F"
                                                            BorderBrush="{DynamicResource GlassBorder}"
                                                            BorderThickness="1"
                                                            Visibility="{Binding ShowMutedBadge, Converter={StaticResource BoolVis}}">
                                                        <TextBlock Text="mute"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource Muted}"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center" />
                                                    </Border>
                                                    <Border Margin="8,0,0,0"
                                                            Padding="6,2"
                                                            CornerRadius="8"
                                                            Background="#20303F"
                                                            BorderBrush="{DynamicResource GlassBorder}"
                                                            BorderThickness="1"
                                                            Visibility="{Binding ShowGroupBadge, Converter={StaticResource BoolVis}}">
                                                        <TextBlock Text="{Binding GroupGlyph}"
                                                                   FontFamily="{StaticResource IconFont}"
                                                                   FontSize="11"
                                                                   Foreground="{Binding GroupGlyphBrush}"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center" />
                                                    </Border>
                                                </StackPanel>
                                            </DockPanel>
                                            <TextBlock Text="{Binding LastMessagePreview}"
                                                       Foreground="{StaticResource Muted}"
                                                       FontSize="{DynamicResource ConversationPreviewFontSize}"
                                                       Margin="0,2,0,0"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top">
                                            <TextBlock Text="{Binding LastMessageTime}"
                                                       FontFamily="{StaticResource Mono}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource Dim}"
                                                       HorizontalAlignment="Right"
                                                       Visibility="{Binding HasLastMessageTime, Converter={StaticResource BoolVis}}" />
                                            <Border CornerRadius="10"
                                                    Background="#3A2A17"
                                                    BorderBrush="{StaticResource GoldAccent}"
                                                    BorderThickness="1"
                                                    Padding="8,3"
                                                    Margin="8,6,0,0"
                                                    Visibility="{Binding HasUnread, Converter={StaticResource BoolVis}}">
                                                <TextBlock Text="{Binding UnreadLabel}" Foreground="{StaticResource White}" FontSize="11" FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Row="2" Margin="0,10,0,0" Padding="10" CornerRadius="12" Background="#5A121C2C" BorderBrush="{DynamicResource GlassBorder}" BorderThickness="1">
                            <TextBlock x:Name="SidebarStatus" FontSize="11" FontFamily="{StaticResource Mono}" Foreground="{StaticResource Muted}" TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" Background="Transparent" ResizeBehavior="PreviousAndNext" />

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="18" Background="{StaticResource GlassPanel}" BorderBrush="{DynamicResource GlassBorder}" BorderThickness="1" Padding="12">
                        <Grid>
                            <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="语"
                                           FontSize="36"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TealAccent}"
                                           Opacity="0.3" />
                                <TextBlock Text="No conversation selected"
                                           FontSize="15"
                                           Foreground="{StaticResource Muted}"
                                           Margin="0,10,0,6"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Your messages are end-to-end encrypted and never leave your device."
                                           FontSize="12"
                                           Foreground="{StaticResource Dim}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           MaxWidth="300" />
                            </StackPanel>
                            <ListBox x:Name="MessageList"
                                      Background="Transparent"
                                      BorderThickness="0"
                                     Padding="0,6,0,0"
                                     Visibility="Collapsed"
                                     SelectionMode="Single"
                                     Focusable="False"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     VirtualizingPanel.ScrollUnit="Pixel"
                                     VirtualizingPanel.CacheLengthUnit="Page"
                                     VirtualizingPanel.CacheLength="1">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel VerticalAlignment="Bottom" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="IsTabStop" Value="False" />
                                        <Setter Property="Opacity" Value="0" />
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform Y="8" />
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="1"
                                                                         Duration="0:0:0.12" />
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                         To="0"
                                                                         Duration="0:0:0.12">
                                                            <DoubleAnimation.EasingFunction>
                                                                <QuadraticEase EasingMode="EaseOut" />
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                            <Border x:Name="LoadMoreBar"
                                    Visibility="Collapsed"
                                    Panel.ZIndex="5"
                                    Padding="10,8"
                                    CornerRadius="12"
                                    Background="{StaticResource GlassOverlay}"
                                    BorderBrush="{DynamicResource GlassBorder}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Margin="0,6,0,0">
                                <TextBlock Text="Loading older messages..." FontSize="11" Foreground="{StaticResource Muted}" />
                            </Border>
                            <ItemsControl x:Name="ToastHost"
                                          Panel.ZIndex="6"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Top"
                                          Margin="0,8,8,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12,10"
                                                MinWidth="280"
                                                MaxWidth="360"
                                                CornerRadius="12"
                                                Background="{Binding BackgroundBrush}"
                                                BorderBrush="{Binding BorderBrush}"
                                                BorderThickness="1"
                                                Opacity="0">
                                            <Border.RenderTransform>
                                                <TranslateTransform X="24" />
                                            </Border.RenderTransform>
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             To="1"
                                                                             Duration="0:0:0.18" />
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                                             To="0"
                                                                             Duration="0:0:0.18">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <QuadraticEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Width="8"
                                                         Height="8"
                                                         Margin="0,3,10,0"
                                                         Fill="{Binding DotBrush}"
                                                         VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Message}"
                                                           Foreground="{Binding ForegroundBrush}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap" />
                                                <Button Grid.Column="2"
                                                        Width="22"
                                                        Height="22"
                                                        Margin="10,0,0,0"
                                                        Padding="0"
                                                        Content="×"
                                                        FontSize="12"
                                                        Style="{StaticResource TermBtn}"
                                                        Click="DismissToast_Click"
                                                        Visibility="{Binding CanDismiss, Converter={StaticResource BoolVis}}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="TypingIndicator" Grid.Row="1" Margin="12,8,12,0" Visibility="Collapsed" FontSize="11" Foreground="{StaticResource Muted}" />
                    <Border x:Name="ComposerPanel" Grid.Row="2" Margin="0,12,0,0" Padding="12" CornerRadius="18" Background="{StaticResource GlassOverlay}" BorderBrush="{DynamicResource GlassBorder}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox x:Name="InputBox" Style="{StaticResource TermInput}" FontFamily="{StaticResource ChatFont}" FontSize="{DynamicResource ComposerFontSize}" MinHeight="52" MaxHeight="132" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Center" IsEnabled="False" KeyDown="InputBox_KeyDown" TextChanged="InputBox_TextChanged" ToolTip="Enter to send. Shift+Enter for a new line." />
                                <TextBlock x:Name="InputPlaceholder" Margin="18,14,18,0" VerticalAlignment="Top" Foreground="{StaticResource Dim}" FontSize="{DynamicResource ComposerPlaceholderFontSize}" Opacity="0.82" IsHitTestVisible="False" Text="Choose a conversation to start chatting" />
                            </Grid>
                            <Button x:Name="BtnEmojiPicker" Grid.Column="1" Margin="10,0,0,0" Padding="10,10" FontSize="16" Content="🙂" Style="{StaticResource TermBtn}" Click="BtnEmojiPicker_Click" ToolTip="Open OpenMoji picker" />
                            <Button x:Name="BtnSend" Grid.Column="2" Margin="10,0,0,0" Padding="18,10" FontSize="13" Content="Send" IsEnabled="False" Style="{StaticResource AccentBtn}" Click="BtnSend_Click" />
                            <Popup x:Name="EmojiPopup" Placement="Top" PlacementTarget="{Binding ElementName=BtnEmojiPicker}" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Padding="10" Width="320" Height="220" CornerRadius="12" Background="{StaticResource GlassOverlay}" BorderBrush="{DynamicResource GlassBorder}" BorderThickness="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <WrapPanel x:Name="EmojiPanel" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid x:Name="AddOverlay" Visibility="Collapsed" Panel.ZIndex="20" Background="#B3000000">
            <Border Width="460" MaxHeight="560" Padding="24" CornerRadius="22" Background="{StaticResource GlassOverlay}" BorderBrush="{DynamicResource GlassBorder}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="结 Add contact or create a group" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource White}" Margin="0,0,0,18" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="TabAddDm" Grid.Column="0" Margin="0,0,8,0" Content="月 Direct" Style="{StaticResource TermBtn}" Click="TabAddDm_Click" />
                        <Button x:Name="TabAddGroup" Grid.Column="1" Margin="8,0,0,0" Content="山 Group" Style="{StaticResource TermBtn}" Click="TabAddGroup_Click" />
                    </Grid>
                    <Border x:Name="AddStatusPanel" Visibility="Collapsed" Margin="0,0,0,12" Padding="10,8" Background="#1A2432" BorderBrush="{DynamicResource GlassBorder}" BorderThickness="1" CornerRadius="10">
                        <TextBlock x:Name="AddStatus" Visibility="Collapsed" FontSize="12" Foreground="{StaticResource Red}" TextWrapping="Wrap" />
                    </Border>
                    <StackPanel x:Name="AddDmForm">
                        <TextBlock Text="Contact user ID" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="AddContactId" Style="{StaticResource TermInput}" Margin="0,0,0,12" />
                        <TextBlock Text="Display name" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="AddContactName" Style="{StaticResource TermInput}" Margin="0,0,0,18" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnConfirmAddContact" Content="Save Friend" Style="{StaticResource AccentBtn}" Click="BtnConfirmAdd_Click" />
                            <Button x:Name="BtnCloseAddOverlay" Grid.Column="1" Margin="10,0,0,0" Content="Close" Style="{StaticResource TermBtn}" Click="BtnCloseOverlay_Click" />
                        </Grid>
                    </StackPanel>
                    <StackPanel x:Name="AddGroupForm" Visibility="Collapsed">
                        <TextBlock x:Name="GroupModeHint" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap" />
                        <TextBlock Text="Group name" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="NewGroupName" Style="{StaticResource TermInput}" Margin="0,0,0,12" />
                        <TextBlock Text="Member user IDs (one per line, optional)" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="GroupMemberIds" Height="110" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Style="{StaticResource TermInput}" Margin="0,0,0,18" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnConfirmCreateGroup" Content="Create group" Style="{StaticResource GroupBtn}" Click="BtnCreateGroup_Click" />
                            <Button x:Name="BtnCloseGroupOverlay" Grid.Column="1" Margin="10,0,0,0" Content="Close" Style="{StaticResource TermBtn}" Click="BtnCloseOverlay_Click" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="SettingsOverlay" Visibility="Collapsed" Panel.ZIndex="25" Background="#B3000000">
            <Border Width="580" MaxHeight="680" Padding="0" CornerRadius="22" Background="{StaticResource GlassOverlay}" BorderBrush="{DynamicResource GlassBorder}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24">
                    <TextBlock Text="系 System" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource White}" Margin="0,0,0,18" />
                    <Border Margin="0,0,0,14"
                            Padding="14,12"
                            CornerRadius="16"
                            Background="#14000000"
                            BorderBrush="{DynamicResource GlassBorder}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Behavior"
                                       Foreground="{StaticResource White}"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                            <CheckBox x:Name="ChkCloseToTrayOnClose"
                                      Margin="0,10,0,0"
                                      Foreground="{StaticResource White}"
                                      FontSize="12"
                                      Content="Closing the window keeps ZLABO running in the tray"
                                      Click="ChkCloseToTrayOnClose_Click" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource Muted}"
                                       FontSize="11"
                                       TextWrapping="Wrap">When enabled, the X button hides the app instead of exiting. Use the tray icon menu to reopen or fully quit.</TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,0,14"
                            Padding="14,12"
                            CornerRadius="16"
                            Background="#14000000"
                            BorderBrush="{DynamicResource GlassBorder}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Startup"
                                       Foreground="{StaticResource White}"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                            <CheckBox x:Name="ChkStartWithWindows"
                                      Margin="0,10,0,0"
                                      Foreground="{StaticResource White}"
                                      FontSize="12"
                                      Content="Start ZLABO when I sign in to Windows"
                                      Click="ChkStartWithWindows_Click" />
                            <CheckBox x:Name="ChkStartHiddenOnStartup"
                                      Margin="0,8,0,0"
                                      Foreground="{StaticResource White}"
                                      FontSize="12"
                                      Content="Start hidden in the tray"
                                      Click="ChkStartHiddenOnStartup_Click" />
                            <TextBlock Margin="0,12,0,6"
                                       Foreground="{StaticResource Muted}"
                                       FontSize="11">Startup delay</TextBlock>
                            <WrapPanel x:Name="StartupDelayPanel">
                                <Button x:Name="BtnStartupDelay0" Tag="0" Margin="0,0,8,8" Content="Off" Style="{StaticResource TermBtn}" Click="StartupDelayButton_Click" />
                                <Button x:Name="BtnStartupDelay15" Tag="15" Margin="0,0,8,8" Content="15 sec" Style="{StaticResource TermBtn}" Click="StartupDelayButton_Click" />
                                <Button x:Name="BtnStartupDelay30" Tag="30" Margin="0,0,8,8" Content="30 sec" Style="{StaticResource TermBtn}" Click="StartupDelayButton_Click" />
                                <Button x:Name="BtnStartupDelay60" Tag="60" Margin="0,0,8,8" Content="60 sec" Style="{StaticResource TermBtn}" Click="StartupDelayButton_Click" />
                            </WrapPanel>
                            <TextBlock x:Name="SettingsStartupHintText"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource Muted}"
                                       FontSize="11"
                                       TextWrapping="Wrap">Startup registration uses the app build you are running right now.</TextBlock>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Version" Foreground="{StaticResource Muted}" FontSize="12" />
                    <TextBlock x:Name="SettingsVersionText" Margin="0,4,0,14" Foreground="{StaticResource White}" FontSize="13" />
                    <TextBlock Text="Update status" Foreground="{StaticResource Muted}" FontSize="12" />
                    <TextBlock x:Name="SettingsUpdateStatusText" Margin="0,4,0,8" Foreground="{StaticResource White}" FontSize="12" TextWrapping="Wrap" />
                    <ProgressBar x:Name="UpdateProgressBar" Height="8" Minimum="0" Maximum="100" Margin="0,0,0,14" Visibility="Collapsed" />
                    <TextBlock Text="Diagnostics" Foreground="{StaticResource Muted}" FontSize="12" />
                    <TextBlock x:Name="SettingsDiagnosticsText" Margin="0,4,0,18" Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="Theme" Foreground="{StaticResource Muted}" FontSize="12" />
                    <WrapPanel Margin="0,6,0,18">
                        <Button x:Name="BtnThemeTeal" Tag="Theme.Teal.xaml" Background="#1A58D7B6" BorderBrush="#4D58D7B6" Style="{StaticResource ThemeSwatchBtn}" Click="ThemeButton_Click" ToolTip="Teal">✓</Button>
                        <Button x:Name="BtnThemeViolet" Tag="Theme.Violet.xaml" Background="#1A9E8CFF" BorderBrush="#409E8CFF" Margin="8,0,0,0" Style="{StaticResource ThemeSwatchBtn}" Click="ThemeButton_Click" ToolTip="Violet" />
                        <Button x:Name="BtnThemeBlue" Tag="Theme.Blue.xaml" Background="#1A7AA2FF" BorderBrush="#407AA2FF" Margin="8,0,0,0" Style="{StaticResource ThemeSwatchBtn}" Click="ThemeButton_Click" ToolTip="Blue" />
                        <Button x:Name="BtnThemeAmber" Tag="Theme.Amber.xaml" Background="#1AF6B15F" BorderBrush="#4DF6B15F" Margin="8,0,0,0" Style="{StaticResource ThemeSwatchBtn}" Click="ThemeButton_Click" ToolTip="Amber" />
                        <Button x:Name="BtnThemeRose" Tag="Theme.Rose.xaml" Background="#1AFF6B96" BorderBrush="#4DFF6B96" Margin="8,0,0,0" Style="{StaticResource ThemeSwatchBtn}" Click="ThemeButton_Click" ToolTip="Rose" />
                    </WrapPanel>
                    <UniformGrid Columns="2" Margin="0,0,0,14">
                        <Button x:Name="BtnCheckUpdates" Content="Check updates" Style="{StaticResource InfoBtn}" Margin="0,0,10,10" Click="BtnCheckUpdates_Click" />
                        <Button x:Name="BtnRestartToUpdate" Content="Restart to update" Style="{StaticResource GroupBtn}" Margin="0,0,0,10" Click="BtnRestartToUpdate_Click" Visibility="Collapsed" />
                        <Button x:Name="BtnOpenLogs" Content="Open logs" Style="{StaticResource InfoBtn}" Margin="0,0,10,0" Click="BtnOpenLogs_Click" />
                        <Button x:Name="BtnOpenData" Content="Open data" Style="{StaticResource AccentBtn}" Click="BtnOpenData_Click" />
                    </UniformGrid>
                    <Border Margin="0,0,0,14"
                            Padding="14,12"
                            CornerRadius="16"
                            Background="#401D1114"
                            BorderBrush="#99693139"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Danger zone"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Red}" />
                            <TextBlock Margin="0,6,0,12"
                                       Foreground="{StaticResource Muted}"
                                       FontSize="12"
                                       TextWrapping="Wrap">Vault nuke permanently destroys local history, contacts, and session data. Use it carefully.</TextBlock>
                            <Button x:Name="BtnOpenNukeOverlay"
                                    Content="Open nuke confirmation"
                                    Style="{StaticResource NukeBtn}"
                                    Click="BtnNuke_Click" />
                        </StackPanel>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnExportDiagnostics" Content="Export diagnostics" Style="{StaticResource InfoBtn}" Click="BtnExportDiagnostics_Click" />
                        <Button Grid.Column="1" Margin="10,0,0,0" Content="Close" Style="{StaticResource TermBtn}" Click="BtnCloseSettings_Click" />
                    </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid x:Name="NukeOverlay" Visibility="Collapsed" Panel.ZIndex="30" Background="#C8000000">
            <Border Width="430" Padding="24" CornerRadius="22" Background="#F9161013" BorderBrush="#6F2D39" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="焚 Vault nuke" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource Red}" Margin="0,0,0,12" />
                    <TextBlock Margin="0,0,0,16" Foreground="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap">This permanently destroys the vault, local history, contacts, and session state. Type NUKE to confirm.</TextBlock>
                    <TextBlock Text="Confirmation" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6" />
                    <TextBox x:Name="NukeConfirm" Style="{StaticResource TermInput}" Margin="0,0,0,18" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnConfirmNuke" Grid.Column="0" Content="Detonate" Style="{StaticResource NukeBtn}" Click="BtnConfirmNuke_Click" />
                        <Button x:Name="BtnCancelNuke" Grid.Column="1" Margin="10,0,0,0" Content="Cancel" Style="{StaticResource TermBtn}" Click="BtnCancelNuke_Click" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

