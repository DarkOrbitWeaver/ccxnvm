    <Style x:Key="ScrollBarTrackButton" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarThumb" TargetType="Thumb">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbChrome"
                            Margin="1"
                            CornerRadius="5"
                            Background="{DynamicResource AccentButtonFill}"
                            BorderBrush="{DynamicResource AccentButtonBorder}"
                            BorderThickness="1" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource AccentButtonHoverFill}" />
                            <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="{DynamicResource AccentButtonHoverBorder}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource AccentButtonHoverFill}" />
                            <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="{DynamicResource TealAccent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
        <Grid Width="{TemplateBinding Width}" Background="Transparent">
            <Border Margin="2,0"
                    CornerRadius="5"
                    Background="{DynamicResource ScrollBarTrackBg}"
                    BorderBrush="{DynamicResource GlassBorder}"
                    BorderThickness="1" />
            <Track x:Name="PART_Track"
                   IsDirectionReversed="True"
                   Focusable="False">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                  Command="{x:Static ScrollBar.PageUpCommand}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollBarThumb}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                  Command="{x:Static ScrollBar.PageDownCommand}" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
        <Grid Height="{TemplateBinding Height}" Background="Transparent">
            <Border Margin="0,2"
                    CornerRadius="5"
                    Background="{DynamicResource ScrollBarTrackBg}"
                    BorderBrush="{DynamicResource GlassBorder}"
                    BorderThickness="1" />
            <Track x:Name="PART_Track"
                   Focusable="False">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                  Command="{x:Static ScrollBar.PageLeftCommand}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollBarThumb}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                  Command="{x:Static ScrollBar.PageRightCommand}" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="10" />
        <Setter Property="Height" Value="10" />
        <Setter Property="MinWidth" Value="10" />
        <Setter Property="MinHeight" Value="10" />
        <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style TargetType="TextBox" x:Key="TermInput">
        <Setter Property="Background" Value="{StaticResource GlassInputBg}" />
        <Setter Property="Foreground" Value="{StaticResource White}" />
        <Setter Property="CaretBrush" Value="{DynamicResource TealAccent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="SelectionBrush" Value="{DynamicResource DimGreen}" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="focusRing"
                            Background="#00000000"
                            BorderBrush="#00000000"
                            BorderThickness="1"
                            CornerRadius="11"
                            SnapsToDevicePixels="True">
                        <Border x:Name="bd"
                                Margin="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="focusRing" Property="BorderBrush" Value="{DynamicResource InputFocusRing}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource TealAccent}" />
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource GlassInputFocusBg}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="focusRing" Property="Opacity" Value="0.55" />
                            <Setter TargetName="bd" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

