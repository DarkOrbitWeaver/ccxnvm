<Window x:Class="Cipher.ActionConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm action"
        Width="460"
        Height="300"
        MinWidth="420"
        MinHeight="280"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="{StaticResource UiFont}"
        Foreground="{StaticResource White}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True">
    <Grid Margin="18">
        <Border Padding="20"
                CornerRadius="22"
                Background="{DynamicResource GlassPanel}"
                BorderBrush="{DynamicResource GlassBorder}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Width="44"
                            Height="44"
                            CornerRadius="22"
                            Background="#401D1114"
                            BorderBrush="#99693139"
                            BorderThickness="1"
                            HorizontalAlignment="Left">
                        <TextBlock Text="!"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Amber}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock x:Name="TitleText"
                               Margin="0,14,0,0"
                               FontSize="22"
                               FontFamily="{StaticResource DisplayFont}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource White}" />
                </StackPanel>

                <TextBlock x:Name="MessageText"
                           Grid.Row="1"
                           Margin="0,18,0,18"
                           FontSize="13"
                           Foreground="{StaticResource Muted}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Top" />

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="HintText"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Dim}"
                               FontSize="11"
                               Text="This action only affects this local app unless stated otherwise." />
                    <Button x:Name="ConfirmButton"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            MinWidth="112"
                            Content="Confirm"
                            Style="{StaticResource NukeBtn}"
                            Click="ConfirmButton_Click" />
                    <Button x:Name="CancelButton"
                            Grid.Column="2"
                            Margin="10,0,0,0"
                            MinWidth="92"
                            Content="Cancel"
                            Style="{StaticResource TermBtn}"
                            Click="CancelButton_Click" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
