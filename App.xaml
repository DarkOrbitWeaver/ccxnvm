<Application x:Class="Cipher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <!-- ── Palette ── -->
        <Color x:Key="BgColor">#0C0C0C</Color>
        <Color x:Key="PanelColor">#111111</Color>
        <Color x:Key="BorderColor">#1F1F1F</Color>
        <Color x:Key="GreenColor">#00FF41</Color>
        <Color x:Key="DimGreenColor">#00882A</Color>
        <Color x:Key="AmberColor">#FFB000</Color>
        <Color x:Key="DimColor">#555555</Color>
        <Color x:Key="RedColor">#FF3333</Color>
        <Color x:Key="WhiteColor">#CCCCCC</Color>

        <SolidColorBrush x:Key="Bg"         Color="{StaticResource BgColor}"/>
        <SolidColorBrush x:Key="Panel"      Color="{StaticResource PanelColor}"/>
        <SolidColorBrush x:Key="Border"     Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="Green"      Color="{StaticResource GreenColor}"/>
        <SolidColorBrush x:Key="DimGreen"   Color="{StaticResource DimGreenColor}"/>
        <SolidColorBrush x:Key="Amber"      Color="{StaticResource AmberColor}"/>
        <SolidColorBrush x:Key="Dim"        Color="{StaticResource DimColor}"/>
        <SolidColorBrush x:Key="Red"        Color="{StaticResource RedColor}"/>
        <SolidColorBrush x:Key="White"      Color="{StaticResource WhiteColor}"/>
        <SolidColorBrush x:Key="Transparent" Color="Transparent"/>

        <!-- ── Base font ── -->
        <FontFamily x:Key="Mono">Consolas, Courier New</FontFamily>

        <!-- ── ScrollBar (minimal, fits terminal look) ── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{StaticResource Bg}"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- ── TextBox ── -->
        <Style TargetType="TextBox" x:Key="TermInput">
            <Setter Property="Background" Value="{StaticResource Bg}"/>
            <Setter Property="Foreground" Value="{StaticResource Green}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Green}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="SelectionBrush" Value="{StaticResource DimGreen}"/>
        </Style>

        <!-- ── Button ── -->
        <Style TargetType="Button" x:Key="TermBtn">
            <Setter Property="Background" Value="{StaticResource Bg}"/>
            <Setter Property="Foreground" Value="{StaticResource Green}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DimGreen}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A2A1A"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Green}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#002200"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="NukeBtn">
            <Setter Property="Background" Value="{StaticResource Bg}"/>
            <Setter Property="Foreground" Value="{StaticResource Red}"/>
            <Setter Property="BorderBrush" Value="#441111"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A0000"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Red}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ListBox (contacts, no selection chrome) ── -->
        <Style TargetType="ListBox" x:Key="TermList">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource Green}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                            BorderThickness="0" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#161616"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#0A1A0A"/>
                                            <Setter TargetName="bd" Property="BorderThickness" Value="2,0,0,0"/>
                                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Green}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
